# edits the windsnow list so that one opaque windsnow will always be visible and the extras will be transparent
console evallua alpha = 0.24; function parseLevelsList(md, list, tbl) for pat in string.gmatch(list, '[^,]+') do if string.find(pat, '%*') then pat = string.gsub(pat, '%*', '.*'); for i = 0, md.Levels.Count - 1 do room = md.Levels[i].Name; if string.find(room, pat) then table.insert(tbl, room); end end else table.insert(tbl, pat); end end end for ai = 0, Celeste.AreaData.Areas.Count - 1 do ad = Celeste.AreaData.Areas[ai]; if ad.SID == 'monikadsidespack/1/9-RidgeOld' then md = ad.Mode[0].MapData; break; end end if md ~= nil then rws = {}; for li = 0, md.Levels.Count - 1 do room = md.Levels[li]; rws[room.Name] = {}; end for fgi = 0, md.Foreground.Children.Count - 1 do fg = md.Foreground.Children[fgi]; if fg.Name == 'windsnow' then onlyStr = nil; excludeStr = nil; if fg.Attributes then eae = fg.Attributes:GetEnumerator(); while eae:MoveNext() do ea = eae.Current; if ea.Key == 'only' then onlyStr = ea.Value; elseif ea.Key == 'exclude' then excludeStr = ea.Value; elseif ea.Key == 'alpha' then return; end end onlyList = {}; if onlyStr then parseLevelsList(md, onlyStr, onlyList); end excludeList = {}; if excludeStr then parseLevelsList(md, excludeStr, excludeList); end for ei = 1, #excludeList do for oi = 1, #onlyList do if onlyList[oi] == excludeList[ei] then table.remove(onlyList, oi); break; end end end for oi = 1, #onlyList do table.insert(rws[onlyList[oi]], fgi); end else return; end end end singles = {}; for room, windsnows in pairs(rws) do if #windsnows == 1 then singles[windsnows[1]] = true; else for _, wsi in pairs(windsnows) do ws = md.Foreground.Children[wsi]; ws.Attributes:Remove('alpha'); ws.Attributes:Add('alpha', alpha); end end end sortedSingles = {}; for single in pairs(singles) do table.insert(sortedSingles, single); end table.sort(sortedSingles); ssi = #sortedSingles; while ssi > 1 do md.Foreground.Children:RemoveAt(sortedSingles[ssi]); ssi = ssi - 1; end sws = sortedSingles[1]; if sws then sws = md.Foreground.Children[sws]; sws.Attributes:Remove('only'); sws.Attributes:Remove('exclude'); sws.Attributes:Remove('alpha'); end end