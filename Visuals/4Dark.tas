# moves pink fog decals to background layer, and makes the extra windsnows transparent
console evallua alpha = 0.24; for ai = 0, Celeste.AreaData.Areas.Count - 1 do ad = Celeste.AreaData.Areas[ai]; if ad.SID == 'monikadsidespack/0/4-Ridge' then md = ad.Mode[1].MapData; break; end end if md ~= nil then for li = 0, md.Levels.Count - 1 do room = md.Levels[li] di = 0 while di < room.FgDecals.Count do decal = room.FgDecals[di] if string.find(decal.Texture, 'mysterycloud') then room.FgDecals:RemoveAt(di) room.BgDecals:Add(decal) else di = di + 1 end end end for fgi = 0, md.Foreground.Children.Count - 1 do fg = md.Foreground.Children[fgi]; if fg.Name == 'windsnow' then eae = fg.Attributes:GetEnumerator(); hide = false; while eae:MoveNext() do ea = eae.Current; if ea.Key == 'only' and string.find(ea.Value, '*a') then hide = true; end end if hide then fg.Attributes:Remove('alpha'); fg.Attributes:Add('alpha', alpha); end end end end