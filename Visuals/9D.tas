# moves the foregrounds in depression, trust, and FGFG to the background, and moves the pink fog decals in final plat room to the background
console evallua for ai = 0, Celeste.AreaData.Areas.Count - 1 do ad = Celeste.AreaData.Areas[ai]; if ad.SID == 'monikadsidespack/0/10-Farewell' then md = ad.Mode[0].MapData; break; end end if md ~= nil then for j = 0, md.Levels.Count - 1 do room = md.Levels[j] k = 0 while k < room.FgDecals.Count do decal = room.FgDecals[k] if string.find(decal.Texture, 'mysterycloud') then room.FgDecals:RemoveAt(k) room.BgDecals:Add(decal) else k = k + 1 end end end fgi = 0; while fgi < md.Foreground.Children.Count do fg = md.Foreground.Children[fgi]; if fg.Name == 'parallax' then eae = fg.Attributes:GetEnumerator(); hide = false; while eae:MoveNext() do ea = eae.Current; if ea.Key == 'texture' and string.find(ea.Value, 'dark') then hide = true; break; end end if hide then md.Background.Children:Add(fg); md.Foreground.Children:RemoveAt(fgi); else fgi = fgi + 1; end else fgi = fgi + 1; end end end