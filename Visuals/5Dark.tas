# makes the mirror fg styleground transparent
console evallua alpha = 0.55; for ai = 0, Celeste.AreaData.Areas.Count - 1 do ad = Celeste.AreaData.Areas[ai]; if ad.SID == 'monikadsidespack/0/5-Temple' then md = ad.Mode[1].MapData; break; end end if md ~= nil then for fgi = 0, md.Foreground.Children.Count - 1 do fg = md.Foreground.Children[fgi]; if fg.Name == 'parallax' then eae = fg.Attributes:GetEnumerator(); hide = false; while eae:MoveNext() do ea = eae.Current; if ea.Key == 'texture' and string.find(ea.Value, 'mirror_veil') then hide = true; break; end end if hide then fg.Attributes:Remove('alpha'); fg.Attributes:Add('alpha', alpha); end end end end